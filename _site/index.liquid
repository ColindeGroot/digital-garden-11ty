<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    
    <link rel="stylesheet" href="/css/wiki.css">

    <title>Digital garden</title>
  </head>
  <body>

  <section class="gitshowcase">
      <h2 class="gitshowcase__title">Mijn GitHub Projecten:</h2>
      <ul class="gitshowcase__list">
        {% for repo in github %}
          <li class="gitshowcase__item">
            <a href="{{ repo.html_url }}" target="_blank" class="gitshowcaselink">{{ repo.name }}</a>
            <p class="gitshowcase__description">{{ repo.description }}</p>
          </li>
        {% endfor %}
      </ul>
  </section>


    <section class="wikis">
      <h2 class="wikis__title">Wiki's</h2>
      <ul class="wikis__list">
        {% for post in collections.wiki %}
        <li class="wikis__item">
          <a href="{{ post.url }}" class="wikis__link">{{ post.fileSlug }}</a>
        </li>
        {% endfor %}
      </ul>
    </section>
  </body>
</html>
