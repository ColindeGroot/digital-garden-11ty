---
title: Home
description: A digital garden showcasing my projects and wiki posts.
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/home.css">

  <title>{{ title }}</title>
</head>

<body>

  {% render "header.liquid" %}

  <main>

    <section class="aboutme" id="about">
      <div class="aboutme__card">
        <img class="aboutme__portrait" src="/assets/images/portrait.png" alt="Portrait photo" />
        <div class="aboutme__content">
          <h2 class="aboutme__title">Colin de Groot</h2>
          <p class="aboutme__text">Welcome to my Digital Garden! <br /> Here you'll find a collection of my projects and
            insights on various topics related to web development.
          </p>
          <p class="aboutme__text">In my garden, I aim to share my knowledge and experiences with others in the hope to
            teach and inspire.
          </p>
        </div>
      </div>
    </section>

    <section class="gitshowcase" id="projects">

      <div class="gitshowcase__wrapper">
        <h2 class="gitshowcase__title">GitHub Projects:</h2>
        <p class="gitshowcase__description"> I created and contributed to multiple projects over the past years. Here
          are some of the projects I've been working on!</p>
      </div>

      <ul class="gitshowcase__list">
        {% for repo in github limit:8%}
        <li class="gitshowcase__item">

          <div class="gitshowcase__icons">
            <span class="gitshowcase__label label">{{ repo.language }}</span>
            <a href="{{ repo.html_url }}" aria-label="Learn more about {{ repo.formattedName }}" target="_blank"
              class="button button--rounded">{% render "icons/link.liquid" %}</a>
          </div>

          <div class="gitshowcase__content">
            <h3>{{ repo.formattedName }}</h3>
            <p>{{ repo.description }}</p>
          </div>
        </li>
        {% endfor %}

        {% if github.size == 0 %}
        <h3>No projects found! </h3>
        <p>
          This is most likely due to the GitHub API rate limit being exceeded. <br> please try
          again later!
        </p>
        {% else %}
        {% comment %} <div class="gitshowcase__buttons">
          <button class="gitshowcase__button button button--primary">Previous</button>
          <button class="gitshowcase__button button button--primary">Next</button>
        </div> {% endcomment %}
        {% endif %}
      </ul>


    </section>

    <section class="wikis" id="wiki">
      <h2 class="wikis__title">Wiki's</h2>

      <div class="wikis__filters">
        <button class="wikis__filter__button button button--primary selected" data-filter="all">All</button>

        {% for tag in collections.wikiTags %}
        <button class="wikis__filter__button button button--primary" data-filter="{{ tag }}">{{ tag }}</button>
        {% endfor %}
      </div>

      <ul class="wikis__list">
        {% for post in collections.wiki %}
        <li class="wikis__list__item{% if post.data.image %} wikis__list__item--with-image{% endif %}"
          data-tags="{{ post.data.tags | join: ',' }}" {% if
          post.data.image%}style="--wiki-image: url('{{ post.data.image }}');" {% endif %}>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.data.summary | truncate: 120 }}</p>
          <a href="{{ post.url }}" class="wikis__link">View full post</a>
        </li>
        {% endfor %}
      </ul>
    </section>

  </main>

</body>

<script>
  // Consider: Replacing the js with a has:(selected) selector in CSS. 
  // JS should stay as backup if selected is not present since its not baseline yet. (No support in safari and firefox yet)

  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll('.wikis__filter__button');
    const blogPosts = document.querySelectorAll('.wikis__list__item');

    filterButtons.forEach(button => {
      button.addEventListener('click', (event) => {

        event.preventDefault();

        const selectedFilter = button.getAttribute('data-filter');

        filterButtons.forEach(btn => btn.classList.remove('selected'));
        button.classList.add('selected');

        blogPosts.forEach(post => {

          const postTags = post.getAttribute('data-tags').split(',');
          const matches = selectedFilter === 'all' || postTags.includes(selectedFilter);

          if (matches) {
            post.classList.remove('wikis__list__item--hidden');
            post.classList.remove('wikis__list__item--fade-in');
            void post.offsetWidth;
            post.classList.add('wikis__list__item--fade-in');
            post.addEventListener('animationend', () => {
              post.classList.remove('wikis__list__item--fade-in');
            }, { once: true });
          } else {
            post.classList.remove('wikis__list__item--fade-in');
            post.classList.add('wikis__list__item--hidden');
          }
        });

      });
    });
  });
</script>

</html>